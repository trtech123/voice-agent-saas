# ============================================
# Supabase
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DIRECT_DB_URL=postgres://postgres.ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# ============================================
# Encryption
# ============================================
CREDENTIAL_KEK=base64-encoded-32-byte-key

# ============================================
# ElevenLabs (Voice AI)
# ============================================
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ============================================
# Gemini (Legacy / Fallback)
# ============================================
GEMINI_API_KEY=your-gemini-key
GEMINI_LIVE_MODEL=models/gemini-3.1-flash-live-preview
GEMINI_VOICE_NAME=Kore
GEMINI_WATCHDOG_IDLE_NUDGE_SEC=45

# ============================================
# Deepgram (STT — unbundled pipeline)
# ============================================
DEEPGRAM_API_KEY=your-deepgram-key

# ============================================
# OpenAI (LLM — unbundled pipeline)
# ============================================
OPENAI_API_KEY=your-openai-key

# ============================================
# Voicenter (SIP trunk)
# ============================================
VOICENTER_PJSIP_ENDPOINT=voicenter_trunk
VOICENTER_SIP_SERVER=185.138.169.235
VOICENTER_SIP_USERNAME=your-username
VOICENTER_SIP_PASSWORD=your-password
VOICENTER_CALLER_ID=your-caller-id
VOICENTER_TRANSPORT=udp

# ============================================
# Asterisk ARI
# ============================================
ASTERISK_ARI_BASE_URL=http://127.0.0.1:8088/ari
ASTERISK_ARI_USERNAME=your-ari-user
ASTERISK_ARI_PASSWORD=your-ari-password
ASTERISK_ARI_APP=voiceagent-saas-media
ASTERISK_MEDIA_FORMAT=slin16
ASTERISK_MEDIA_CONNECTION_NAME=voiceagent_saas_media

# ============================================
# SIP Gateway
# ============================================
SIP_GATEWAY_API_KEY=your-sip-gateway-api-key
SIP_GATEWAY_EVENTS_SECRET=your-sip-events-secret

# ============================================
# Redis (BullMQ job queue)
# ============================================
REDIS_URL=redis://:password@localhost:6379

# ============================================
# Voice Engine
# ============================================
PORT=8091
PUBLIC_BASE_URL=http://localhost:8091

# ============================================
# Vertex AI EU (optional — low latency)
# ============================================
USE_VERTEX_AI=false
GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION=europe-west1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ============================================
# VAD Tuning (unbundled pipeline)
# ============================================
VAD_RMS_THRESHOLD=800
VAD_SILENCE_DEBOUNCE_MS=700
VAD_SANITY_GAP_MS=2000
VAD_CONSECUTIVE_SILENT_FRAMES=3
VAD_AGENT_AUDIO_TAIL_MS=200

# ============================================
# Unbundled Pipeline Tunables
# ============================================
DEEPGRAM_BARGE_GATE_MS=150
LLM_MAX_ROUNDS_PER_CALL=50
LLM_HISTORY_WINDOW_TURNS=20
BARGE_LOOP_THRESHOLD=5
BARGE_LOOP_WINDOW_MS=30000

# ============================================
# WhatsApp (optional)
# ============================================
WHATSAPP_ACCESS_TOKEN=your-meta-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
